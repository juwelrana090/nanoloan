{
  "expo": {
    "name": "Nano Loan",
    "slug": "nano-loan",
    "version": "1.0.0",
    "scheme": "nanoloan",
    "platforms": [
      "ios",
      "android"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/android-hide-title.js",
      "./plugins/android-manifest-fix.js",
      "./plugins/android-release-signing.js",
      "./plugins/android-play-console-fixes.js",
      "./plugins/android-proguard-rules.js",
      "./plugins/android-disable-lint.js",
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "barStyle": "light",
          "visibility": "visible"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#00C897",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#E5FCFF"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libjsc.so",
                "**/libfb.so",
                "**/libhermes.so",
                "**/libhermes-executor-debug.so",
                "**/libhermes-executor-release.so",
                "**/libhermes-inspector.so"
              ],
              "exclude": [
                "META-INF/DEPENDENCIES",
                "META-INF/LICENSE",
                "META-INF/LICENSE.txt",
                "META-INF/license.txt",
                "META-INF/NOTICE",
                "META-INF/NOTICE.txt",
                "META-INF/notice.txt",
                "META-INF/ASL2.0",
                "META-INF/INDEX.LIST",
                "**/AndroidUIScheduler$*.class",
                "**/*.kotlin_module",
                "META-INF/*.version",
                "META-INF/proguard/**",
                "META-INF/services/javax.annotation.processing.Processor"
              ]
            },
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "usesCleartextTraffic": false,
            "extraMavenRepos": []
          }
        }
      ],
      [
        "react-native-permissions",
        {
          "permissions": [
            "CAMERA"
          ],
          "iosPermissions": [
            "Camera"
          ]
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0DB7AF",
          "sounds": [
            "./assets/sounds/ringtone.mp3"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "assets/images/*",
      "assets/sounds/*",
      "assets/fonts/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#00C897"
      },
      "package": "com.nano.loan.app",
      "permissions": [
        "android.permission.WAKE_LOCK",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "compileSdkVersion": 36,
      "targetSdkVersion": 36,
      "minSdkVersion": 24,
      "versionCode": 3,
      "compileOptions": {
        "sourceCompatibility": "1.8",
        "targetCompatibility": "1.8"
      },
      "gradleProperties": {
        "org.gradle.jvmargs": "-Xmx4096m -XX:MaxMetaspaceSize=512m -XX:+HeapDumpOnOutOfMemoryError",
        "org.gradle.daemon": "false",
        "org.gradle.parallel": "true",
        "org.gradle.caching": "true",
        "android.useAndroidX": "true",
        "android.enableJetifier": "true",
        "android.enableDexingArtifactTransform.desugaring": "false",
        "android.packagingOptions.pickFirsts": "**/libc++_shared.so,**/libjsc.so,**/libfb.so,**/libhermes.so",
        "android.packagingOptions.excludes": "META-INF/DEPENDENCIES,META-INF/LICENSE,META-INF/LICENSE.txt,META-INF/NOTICE,META-INF/NOTICE.txt",
        "android.lint.ignoreSupportLibraryWarnings": "true",
        "android.bundle.enableUncompressedNativeLibs": "true",
        "newArchEnabled": "false"
      },
      "extraGradlePlugins": [
        {
          "id": "com.google.gms.google-services",
          "version": "4.4.3"
        }
      ],
      "dependencies": [
        "implementation platform('com.google.firebase:firebase-bom:34.2.0')",
        "implementation 'com.google.firebase:firebase-analytics'"
      ],
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "router": {},
      "apiUrl": "https://backend-nanoloan.giize.com"
    }
  }
}