{
  "name": "nano-loan",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "android:device": "npx expo run:android --device",
    "android:all": "npx expo run:android",
    "clean:full": "npm cache clean --force && npm install && npx expo install --fix",
    "clean:android": "npx expo prebuild --clean && cd android && ./gradlew clean && cd ..",
    "reset:full": "npm run clean:full && npm run clean:android",
    "fresh:start": "npm run reset:full && npx expo start --clear",
    "fresh:android": "npm run reset:full && npx expo run:android"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
